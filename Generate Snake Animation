# Gera a animação da "cobrinha" (snake) comendo os commits do seu perfil.
# CAMINHO CORRETO no repositório JPGC02/JPGC02:
#   .github/workflows/snake.yml
name: Generate Snake Animation

on:
  schedule:
    # Roda a cada 12 horas (ajuste se quiser)
    - cron: "0 */12 * * *"
  # Permite rodar manualmente na aba Actions
  workflow_dispatch:
  # Roda a cada push na branch principal
  push:
    branches:
      - main

jobs:
  generate:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    permissions:
      contents: write
    steps:
      - name: Gerar snake.svg
        uses: Platane/snk/svg-only@v3
        with:
          github_user_name: JPGC02
          outputs: |
            dist/github-snake.svg
            dist/github-snake-dark.svg?palette=github-dark
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Publicar na branch "output"
        uses: crazy-max/ghaction-github-pages@v4
        with:
          target_branch: output
          build_dir: dist
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
